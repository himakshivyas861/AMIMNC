{
	"name": "dataingestionfromsearchio",
	"properties": {
		"description": "news data ingestion",
		"activities": [
			{
				"name": "Copy data1",
				"type": "Copy",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "RestSource",
						"httpRequestTimeout": "00:01:40",
						"requestInterval": "00.00:00:00.010",
						"requestMethod": "GET",
						"paginationRules": {
							"supportRFC5988": "true"
						}
					},
					"sink": {
						"type": "JsonSink",
						"storeSettings": {
							"type": "AzureBlobStorageWriteSettings"
						},
						"formatSettings": {
							"type": "JsonWriteSettings"
						}
					},
					"enableStaging": false
				},
				"inputs": [
					{
						"referenceName": "RestResource2",
						"type": "DatasetReference",
						"parameters": {
							"base": "@pipeline().parameters.baseUrl",
							"endpoint": {
								"value": "@pipeline().parameters.endpoint",
								"type": "Expression"
							},
							"engine": "@pipeline().parameters.engine",
							"query": {
								"value": "@item.name()",
								"type": "Expression"
							},
							"apikey": {
								"value": "@pipeline().parameters.apikey",
								"type": "Expression"
							}
						}
					}
				],
				"outputs": [
					{
						"referenceName": "Json1",
						"type": "DatasetReference"
					}
				]
			}
		],
		"parameters": {
			"baseurl": {
				"type": "string"
			},
			"endpoint": {
				"type": "String"
			},
			"apikey": {
				"type": "string"
			},
			"engine": {
				"type": "string"
			},
			"query": {
				"type": "string"
			}
		},
		"folder": {
			"name": "KESCO/restapidataingestion"
		},
		"annotations": []
	}
}